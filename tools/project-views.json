      "visible_fields": ["title", "assignees", "priority", "sub_issues_progress"]
    },
    {
      "id": "TBD-next-up",
      "name": "Next up",
      "layout": "TABLE_LAYOUT",
      "filter": "is:open status:Todo (priority:P0 OR priority:P1)",
