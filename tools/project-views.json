      "sort_by": [{ "field": "priority", "direction": "ASC" }],
      "visible_fields": ["title", "milestone", "sub_issues_progress"]
    },
    {
      "id": "TBD-v1.1-epic-tree",
      "name": "v1.1 epic tree",
      "layout": "TABLE_LAYOUT",
      "filter": "is:open milestone:v1.1",
      "group_by": ["parent_issue"],
      "sort_by": [],
      "visible_fields": ["title", "status", "priority", "sub_issues_progress", "blocked_by"]
    },
    {
      "id": "TBD-by-owner",
      "name": "All work by owner",
      "layout": "BOARD_LAYOUT",
      "filter": "is:open",
      "group_by": ["assignees"],
      "sort_by": [{ "field": "priority", "direction": "ASC" }],
      "visible_fields": ["title", "status", "priority", "milestone"]
    },
    {
      "id": "TBD-unmilestoned",
      "name": "Backlog (unmilestoned)",
      "layout": "TABLE_LAYOUT",
      "filter": "is:open no:milestone",
      "group_by": [],
      "sort_by": [{ "field": "priority", "direction": "ASC" }],
      "visible_fields": ["title", "priority", "labels"]
    }
  ],
  "notes": [
    "GitHub Projects v2 GraphQL API does not currently expose view creation (no createProjectV2View mutation).",
