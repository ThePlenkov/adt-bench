  "views": [
    {
      "id": "TBD-roadmap",
      "name": "Roadmap",
      "layout": "ROADMAP_LAYOUT",
      "filter": "is:open",
      "group_by": ["milestone"],
      "sort_by": [{ "field": "priority", "direction": "ASC" }],
